# Copy to .env and fill in. .env is gitignored.
# Production values live as Fly secrets (see CLAUDE.md → Execution protocol).

# === Gemini (server-side, never exposed to the browser) ===
# Get from https://aistudio.google.com/apikey or Google Cloud Console.
GEMINI_KEY=

# === Cloudflare Turnstile ===
# Public site key — safe to commit; baked into the Vite bundle.
# Configure the widget mode to "Invisible" in the Cloudflare dashboard so the
# green success box never appears on screen.
VITE_TURNSTILE_SITE_KEY=
# Paired secret — server-side only.
TURNSTILE_SECRET=

# === Proxy tunables (all optional; defaults shown) ===
# Comma-separated IPs that bypass per-IP cap AND Turnstile verification.
# Use for your own dev machine; leave empty in prod unless you have a static IP.
OWNER_IPS=
# Per-IP sliding window: requests / window-minutes.
IP_LIMIT=200
IP_WINDOW_MINUTES=60
# Global daily cap (UTC). Hard ceiling against runaway cost.
DAILY_CAP=1200
# Gemini model — pinned. No silent fallback to a pricier model.
GEMINI_MODEL=gemini-3-flash-preview
# Retry on 429/5xx from Gemini before surfacing failure to the client.
RETRY_MAX=3
RETRY_BASE_MS=400
GEMINI_TIMEOUT_MS=20000
TURNSTILE_TIMEOUT_MS=10000

# === ReactBits (build-time only; not used at runtime) ===
REACTBITS_LICENSE_KEY=
