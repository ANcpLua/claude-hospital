# Copy to .env for local dev. None of these are secrets —
# production values live in Fly secrets and fly.toml.

# Cloudflare Turnstile — always-pass test keys for local dev.
# Replace with your real keys only if you want to exercise the
# real challenge flow locally.
#   Site key  (public, inlined into client bundle):
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   Secret key (server-side, used by bun server/index.ts):
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# Gemini — get a free key at https://aistudio.google.com/app/apikey
GEMINI_KEY=

# Optional overrides (server/index.ts). Defaults are fine.
# PORT=8080
# DAILY_CAP=1200
# IP_LIMIT=30
# IP_WINDOW_MINUTES=60
# GEMINI_MODEL=gemini-flash-latest
# ALLOWED_ORIGINS=https://claude-hospital.fly.dev,http://localhost:5173
